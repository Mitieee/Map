<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <title>Chamada de Emergência</title>
    <link
      rel="shortcut icon"
      href="frontend/imagens/emergencia.png"
      type="image/x-icon"
    />
    <style>
      body {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        margin: 0;
        font-family: Arial;
      }

      .container {
        max-width: 400px;
        padding: 20px;
        box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.1);
        text-align: center;
        width: 100%;
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .img {
        height: 120px;
        width: 120px;
        border: 2px solid black;
        cursor: pointer;
      }

      input[type="radio"] {
        display: none;
      }

      label img {
        border: 2px solid black;
      }

      input[type="radio"]:checked + label img {
        border-color: red;
        transform: scale(1.1);
      }

      button {
        font-size: 18px;
        font-weight: 600;
        background-color: #40dd00;
        border-radius: 8px;
        border: 0;
        padding: 15px;
        width: 100%;
        cursor: pointer;
      }

      .button2 {
        border: 2px solid black;
        font-size: 18px;
        font-weight: 600;
        border-radius: 8px;
        padding: 15px;
        width: 100%;
        cursor: pointer;
        border: 0;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <% if (usuario) { %>
      <h2>Informações do Usuário</h2>
      <p><strong>Nome:</strong> <%= usuario.nome %></p>
      <p><strong>Data de Nascimento:</strong> <%= usuario.data_nascimento %></p>
      <p><strong>Tipo Sanguíneo:</strong> <%= usuario.tipo %></p>
      <p><strong>Peso:</strong> <%= usuario.peso %> kg</p>
      <p><strong>Altura:</strong> <%= usuario.altura %> cm</p>

      <form action="/cadastro" method="GET">
        <button class="button2" type="submit">Editar Dados Pessoais</button>
      </form>
      <% } else { %>
      <h2>Informações do Usuário</h2>
      <p><strong>Nome:</strong> Não cadastrado</p>
      <p><strong>Data de Nascimento:</strong> Não cadastrado</p>
      <p><strong>Tipo Sanguíneo:</strong> Não cadastrado</p>
      <p><strong>Peso:</strong> Não cadastrado</p>
      <p><strong>Altura:</strong> Não cadastrado</p>

      <!-- Exibindo a mensagem no botão -->
      <form action="/cadastro" method="GET">
        <button class="button2" type="submit">Cadastre-se</button>
      </form>
      <% } %>

      <h2>Chamada de Emergência</h2>
      <form id="emergenciaForm">
        <input type="radio" id="policia" name="emergencia" value="policia" />
        <label for="policia"
          ><img
            class="img"
            src="https://cdn-icons-png.flaticon.com/512/6310/6310025.png"
            alt="policia"
        /></label>
        <input type="radio" id="bombeiro" name="emergencia" value="bombeiro" />
        <label for="bombeiro"
          ><img
            class="img"
            src="https://cdn-icons-png.flaticon.com/512/2264/2264252.png"
            alt="bombeiro"
        /></label>
        <input
          type="radio"
          id="emergencia"
          name="emergencia"
          value="emergencia"
        />
        <label for="emergencia"
          ><img
            class="img"
            src="https://img.freepik.com/vetores-premium/icone-de-ambulancia-carro-de-emergencia-medica-transporte-paramedico_176411-2886.jpg"
            alt="Emergência Médica"
        /></label>
        <br /><br />
      </form>

      <a href="/local.html">
        <button type="button">Enviar Emergência</button>
      </a>
    </div>
  </body>
</html>
